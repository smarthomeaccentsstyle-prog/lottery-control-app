# Example for public deployment
HOST=0.0.0.0
PORT=4000

# Use a persistent volume path in production
DATA_DIR=/data
SESSION_TTL_HOURS=24
REQUEST_BODY_LIMIT_BYTES=262144

# Lock cross-origin API access to your real frontend domains in production
# CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Optional manual override if frontend is hosted separately
# REACT_APP_API_BASE_URL=https://your-api-domain.example/api
